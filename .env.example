# Environment selection
ACTIVE_DB=local
USE_CLOUD_PROXY=false
DEBUG=1

# Django settings
SECRET_KEY=replace_with_local_secret_key
ALLOWED_HOSTS=localhost,127.0.0.1,nginx

# Docker PostGIS
POSTGRES_DB=stayandtrek
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace_with_local_postgres_password
DB_HOST=db
DB_PORT=5432
DATABASE_URL=postgres://postgres:replace_with_local_postgres_password@db:5432/stayandtrek

# Local PostGIS
LOCAL_DB_NAME=webmapping_db
LOCAL_DB_USER=your_local_database_user
LOCAL_DB_PASSWORD=
LOCAL_DB_HOST=127.0.0.1
LOCAL_DB_PORT=5432

# Cloud SQL / remote PostGIS
NEW_DB_NAME=stay_and_trek
NEW_DB_USER=postgres
NEW_DB_PASSWORD=replace_with_cloud_sql_password
NEW_DB_HOST=127.0.0.1
NEW_DB_PORT=5432
OLD_DB_NAME=postgres
OLD_DB_USER=postgres
OLD_DB_PASSWORD=replace_with_old_database_password
OLD_DB_HOST=replace_with_old_database_host
OLD_DB_PORT=5432

# API keys
OPENWEATHERMAP_API_KEY=replace_with_openweathermap_api_key
EXPO_PUBLIC_OPENWEATHERMAP_API_KEY=replace_with_openweathermap_api_key

# Mobile API configuration
EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
EXPO_PUBLIC_API_HOST=127.0.0.1
EXPO_PUBLIC_PRODUCTION_API_URL=https://example.run.app

# Optional server settings
LANGUAGE_CODE=en-us
TIME_ZONE=UTC
PORT=8080
